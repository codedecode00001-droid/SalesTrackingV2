@page
@model Point_of_Sale.Pages.ReturnModel
@{
    ViewData["PageTitle"] = "Return Product";
}

<style>
    .text-right {
        text-align: right;
    }
</style>

<!--begin::This is for the Details-->
<div class="row">
    <!--begin::Different Width-->
    <div class="card card-danger card-outline mb-4">
        <!--begin::Header-->
        <div class="card-header"><div class="card-title">Return Orders</div></div>
        <!--end::Header-->

        <div id="ordersContainer"></div>

        <!--begin::Modal for asking how many qr code create-->
        <div class="modal fade" id="qrQtyModal" tabindex="-1">
            <div class="modal-dialog modal-sm">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">Print QR Code</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body text-center">
                        <label class="form-label">How many QR codes?</label>
                        <input type="number" id="qrQty" class="form-control text-center" value="1" min="1">
                    </div>

                    <div class="modal-footer justify-content-center">
                        <button class="btn btn-primary" onclick="confirmQRPrint()">Generate</button>
                    </div>

                </div>
            </div>
        </div>
        <!--end::Modal for asking how many qr code create-->
    </div>
</div>
<!--end::This is for the Details-->

<script src="~/scripts/returnprod.js"></script>