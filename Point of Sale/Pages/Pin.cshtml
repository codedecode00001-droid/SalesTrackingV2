@page
@model Point_of_Sale.Pages.PinModel
@{
     ViewData["PageTitle"] = "Pin";
}

<!--begin::This is for the Details-->
<div class="row">
    <!--begin::Different Width-->
    <div class="card card-primary card-outline mb-4">
        <!--begin::Header-->
        <div class="card-header"><div class="card-title">User Details</div></div>
        <!--end::Header-->

        <form id="userForm" class="needs-validation" novalidate>
            <!--begin::Body-->
            <div class="card-body">
                <dl class="row">
                    <div class="row mb-3">
                        <input type="hidden" id="Id" value="0">
                        <div class="col-md-4">
                            <label class="form-label">First Name</label>
                            <input id="fname" class="form-control" required />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Middle Name</label>
                            <input id="mname" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Last Name</label>
                            <input id="lname" class="form-control" required />
                        </div>
                    </div>


                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Position</label>
                            <select id="positionDropdown" class="form-select">
                                <option value="">Select Position</option>
                                <option value="Admin">Admin</option>
                                <option value="Sales Purchasing">Sales Purchasing</option>
                                <option value="Staff">Staff</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label d-block">Status</label>

                            <div class="form-check form-check-inline">
                                <input class="form-check-input"
                                       type="radio"
                                       name="choice"
                                       id="option1"
                                       value="Active"
                                       checked>
                                <label class="form-check-label">Active</label>
                            </div>

                            <div class="form-check form-check-inline">
                                <input class="form-check-input"
                                       type="radio"
                                       name="choice"
                                       id="option2"
                                       value="Inactive">
                                <label class="form-check-label">Inactive</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Pin Code</label>

                            <div class="input-group">
                                <input id="pinCode"
                                       class="form-control"
                                       readonly />

                                <button type="button"
                                        class="btn btn-secondary"
                                        onclick="generatePin()">
                                    Generate
                                </button>
                            </div>
                        </div>
                    </div>
                </dl>

                <!--begin::Alert Message-->
                <div id="msg"
                     class="alert alert-dismissible fade show d-none mt-3"
                     role="alert">
                    <button type="button"
                            class="btn-close"
                            aria-label="Close"
                            onclick="hideMessage()"></button>
                </div>
                <!--end::Message-->
            </div>
            <!--end::Body-->
            <!--begin::Footer-->
            <div class="card-footer">
                <button type="submit"
                        class="btn btn-primary float-end"
                        id="btnSaveUser">
                    Save
                </button>
            </div>
            <!--end::Footer-->
        </form>
    </div>
</div>
<!--end::This is for the Details-->
<!--begin::For the List-->
<div class="row">
    <!--begin::Different Width-->
    <div class="card card-danger card-outline mb-4">
        <!--begin::Header-->
        <div class="card-header"><div class="card-title">User List</div></div>
        <!--end::Header-->
        <!--begin::Body-->
        <div class="card-body">
            <!--begin::Body-->
            <div class="card-body">
                <table id="example" class="table table-striped" style="width:100%">
                    <thead>
                        <tr>
                            <th>First Name</th>
                            <th>Middle Name</th>
                            <th>Last Name</th>
                            <th>Position</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="userTable"></tbody>
                </table>
            </div>
            <!--end::Body-->
        </div>
        <!--end::Body-->
    </div>
    <!--end::Different Width-->
</div>
<!--end::End of the List-->

<script src="~/scripts/pin.js"></script>