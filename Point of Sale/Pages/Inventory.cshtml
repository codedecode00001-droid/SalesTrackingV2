@page
@model InventoryModel
@{
    ViewData["PageTitle"] = "Inventory";
}


<!--begin::Filter-->
<div class="row">
    <!--begin::Filter Card-->
    <div class="card card-danger card-outline mb-4">
        <div class="card-header">
            <div class="card-title">Filters</div>
        </div>

        <div class="card-body">
            <form id="filterForm">
                <div class="row align-items-end g-3">

                    <div class="col-md-4">
                        <label for="categoryDropdownInv" class="form-label">Category</label>
                        <select class="form-select" id="categoryDropdownInv" required>
                            <!-- Options added dynamically -->
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label for="productDropdownInv" class="form-label">Product</label>
                        <select class="form-select" id="productDropdownInv" disabled required>
                            <option value="">-- Select Product --</option>
                            <!-- Options added dynamically -->
                        </select>
                    </div>
                </div>
            </form>
        </div>
    </div>
    <!--end::Filter Card-->
</div>
<!--end::End Filter-->

<!--begin::Table Inventory-->
<div class="row">
    <!--begin::Different Width-->
    <div class="card card-danger card-outline mb-4">
        <!--begin::Header-->
        <div class="card-header">
            <div class="card-title">Inventory List</div>
            <div class="d-flex">
                <button class="btn btn-success ms-auto" onclick="exportInventoryToExcel(currentInventory)">
                    <i class="fa-solid fa-file-csv"></i> Export Excel
                </button>
            </div>
        </div>
        <!--end::Header-->

        <!--begin::Body-->
        <div class="card-body">
            <!--begin::Body-->
            <div class="card-body">
                <table id="example" class="table table-striped">
                    <thead>
                        <tr>
                            <th>Category Name</th>
                            <th>Product Name</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Date Expired</th>
                            <th>Status</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody id="inventoryTable"></tbody>
                </table>
            </div>
            <!--end::Body-->
        </div>
        <!--end::Body-->
    </div>
    <!--end::Different Width-->
</div>
<!--end::Table Inventory-->
<script src="~/scripts/inventory.js"></script>