                            <li class="nav-item">
                                <a href="#" class="nav-link">
                                    <i class="nav-icon fa-solid fa-table-list"></i>
                                    <p>
                                        Inventory
                                        <i class="nav-arrow fa-solid fa-angle-right"></i>
                                    </p>
                                </a>

                                <ul class="nav nav-treeview">
                                    <li class="nav-item">
                                        <a class="nav-link @IsActive("/Category")" asp-page="/Category">
                                            <i class="nav-icon fa-solid fa-circle"></i>
                                            <p>Manage Category</p>
                                        </a>
                                    </li>

                                    <li class="nav-item">
                                        <a class="nav-link @IsActive("/Product")" asp-page="/Product">
                                            <i class="nav-icon fa-solid fa-circle"></i>
                                            <p>Manage Product</p>
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        <!-- Report -->
                        @if (HasRole("Admin"))
                        {
                            <li class="nav-item">
                                <a href="#" class="nav-link">
                                    <i class="nav-icon fa-solid fa-clipboard-list"></i>
                                    <p>
                                        Report
                                        <i class="nav-arrow fa-solid fa-angle-right"></i>
                                    </p>
                                </a>

                                <ul class="nav nav-treeview">
                                    <li class="nav-item">
                                        <a class="nav-link @IsActive("/Inventory")" asp-page="/Inventory">
                                            <i class="nav-icon fa-solid fa-circle"></i>
                                            <p>Product List</p>
                                        </a>
                                    </li>

                                    <li class="nav-item">
                                        <a class="nav-link @IsActive("/Report")" asp-page="/Report">
                                            <i class="nav-icon fa-solid fa-circle"></i>
                                            <p>Sales</p>
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        <!-- Settings -->
                        @if (HasRole("Admin"))
                        {
                            <li class="nav-item">
                                <a href="#" class="nav-link">
                                    <i class="nav-icon fa-solid fa-gear"></i>
                                    <p>
                                        Settings
                                        <i class="nav-arrow fa-solid fa-angle-right"></i>
                                    </p>
                                </a>

                                <ul class="nav nav-treeview">
                                    <li class="nav-item">
                                        <a class="nav-link @IsActive("/Pin")" asp-page="/Pin">
                                            <i class="nav-icon fa-solid fa-circle"></i>
