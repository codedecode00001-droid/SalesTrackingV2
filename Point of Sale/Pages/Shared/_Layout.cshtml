                                    </p>
                                </a>
                                <ul class="nav nav-treeview">
                                    <li class="nav-item">
                                        <a class="nav-link @IsActive("/Orders")" asp-page="/Orders">
                                            <i class="nav-icon fa-solid fa-circle"></i>
                                            <p>Orders</p>
                                        </a>
                                    </li>

                                    <li class="nav-item">
                                        <a class="nav-link @IsActive("/Return")" asp-page="/Return">
                                            <i class="nav-icon fa-solid fa-circle"></i>
                                            <p>Return Item</p>
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        <!-- Inventory -->
                        @if (HasRole("Admin"))
