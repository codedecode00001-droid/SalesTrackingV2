            <!--begin::Sidebar Brand-->
            <div class="sidebar-brand">
                <!--begin::Brand Link-->
                <a asp-page="/Index" class="brand-link">
                    <!--begin::Brand Image-->
                    <img src="~/assets/img/sales tracking.png" alt="Sales Logo"
